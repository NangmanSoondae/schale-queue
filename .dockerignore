# ============================================================================
#  Docker 빌드 컨텍스트 제외 (Phase 5)
#  · 빌드 산출물·시크릿·프론트·문서 결과물을 컨텍스트에서 제외해 전송량·노출을 줄인다.
#  · gradlew/gradle/settings·build.gradle/backend 소스는 빌드에 필요하므로 제외하지 않는다.
# ============================================================================

# 빌드 산출물·캐시 (이미지 안에서 새로 빌드)
**/build/
**/.gradle/
.gradle/

# 시크릿 (절대 컨텍스트에 포함 금지 — §5.3.2)
.env
**/application-secret.yml
.mcp.json

# 형상 관리 / IDE
.git/
.idea/
*.iml
.vscode/

# 이 슬라이스 범위 밖 (이미지 빌드에 불필요)
frontend/
docs/
**/result/

# OS 잡파일
.DS_Store
Thumbs.db
