application-secret.yml
application-secret.yaml
application-secret.properties
**/application-secret*.yml
**/application-secret*.yaml
**/application-secret*.properties
.env
.env.*
!.env.example
*.local
.mcp.json
secrets/
*.pem
*.key
*.p12
*.keystore

# ---------------------------------------------------------------------------
#  ☕ Java
# ---------------------------------------------------------------------------
*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# ---------------------------------------------------------------------------
#  🐘 Gradle
# ---------------------------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
gradle-app.setting
.gradletasknamecache

# ---------------------------------------------------------------------------
