# ============================================================================
#  Schale Queue - 환경변수 템플릿 (.env.example)
#  ----------------------------------------------------------------------------
#  이 파일은 '키 목록'만 공유하는 안전한 템플릿이다 (커밋 대상).
#  실제 사용 시: 복사하여 .env 를 만들고 실제 값을 채운다.  →  cp .env.example .env
#  .env 는 .gitignore 로 차단되어 절대 커밋되지 않는다. (§5.3.2)
# ============================================================================

# --- Database (MariaDB) ---
# DB_NAME / DB_USERNAME / DB_PASSWORD / DB_ROOT_PASSWORD 는 docker-compose 가 참조한다.
DB_NAME=schale_queue
DB_USERNAME=schale
DB_PASSWORD=changeme             # ← 실제 비밀번호로 교체 (절대 커밋 금지)
DB_ROOT_PASSWORD=changeme_root   # ← MariaDB root 비밀번호 (절대 커밋 금지)
# 애플리케이션(JPA) 접속 URL
DB_URL=jdbc:mariadb://localhost:3306/schale_queue

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Server ---
SERVER_PORT=8080
