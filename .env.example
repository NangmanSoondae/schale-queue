# ============================================================================
#  Schale Queue - 환경변수 템플릿 (.env.example)
#  ----------------------------------------------------------------------------
#  이 파일은 '키 목록'만 공유하는 안전한 템플릿이다 (커밋 대상).
#  실제 사용 시: 복사하여 .env 를 만들고 실제 값을 채운다.  →  cp .env.example .env
#  .env 는 .gitignore 로 차단되어 절대 커밋되지 않는다. (§5.3.2)
# ============================================================================

# --- Database (MariaDB) ---
# DB_NAME / DB_USERNAME / DB_PASSWORD / DB_ROOT_PASSWORD 는 docker-compose 가 참조한다.
DB_NAME=schale_queue
DB_USERNAME=schale
DB_PASSWORD=changeme             # ← 실제 비밀번호로 교체 (절대 커밋 금지)
DB_ROOT_PASSWORD=changeme_root   # ← MariaDB root 비밀번호 (절대 커밋 금지)
# 애플리케이션(JPA) 접속 URL
DB_URL=jdbc:mariadb://localhost:3306/schale_queue

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Kafka (후방 이벤트 파이프라인, ADR-002) ---
# 호스트에서 bootRun/부하툴 실행 시: localhost:9092
# 컨테이너(--profile app)로 실행 시엔 compose 가 kafka:29092 를 자동 주입하므로 이 값은 무시된다.
KAFKA_BOOTSTRAP=localhost:9092

# --- Server ---
SERVER_PORT=8080
# 풀스택(--profile app) 시 api 컨테이너의 '호스트' 노출 포트. 8080 을 다른 프로세스가 점유 중이면
# 충돌을 피하려 다른 값으로 바꾼다(컨테이너 내부 포트는 8080 고정). 미설정 시 8080.
# (notify-gateway 는 2026-07-06 부로 8081 로 이전해 기본 8080 과 더는 충돌하지 않는다.)
API_PORT=8080
# 풀스택(--profile app) 시 frontend(nginx) 컨테이너의 호스트 노출 포트. 미설정 시 3000.
FRONTEND_PORT=3000

# --- Notifications (notify-gateway 1차 / Discord 웹훅 폴백) ---
# Claude Code 작업 알림 프로토콜(§5.3.4)은 1차로 공용 알림 게이트웨이를 호출한다.
# 🔒 모두 시크릿이다. .env 에만 채우고 절대 커밋하지 않는다.
#
# [1차] 게이트웨이 API — 채널·내용만 전달, 실제 웹훅 URL은 게이트웨이가 보유(시크릿 중앙화).
# 게이트웨이는 호스트 8081 에서 기동한다(게이트웨이 레포 PR #38, 2026-07-06 — 8080 은 schale-api 가 사용).
# ⚠️ 소비 주체가 worker '컨테이너'(NotifyGatewayClient)이므로 localhost 가 아니라 host.docker.internal 을
# 쓴다(컨테이너의 localhost 는 자기 자신). Docker Desktop 은 호스트에서도 이 이름을 해석하므로
# 호스트 측 호출(§5.3.4 curl)에도 같은 값이 동작한다.
NOTIFY_GATEWAY_URL=            # 예: http://host.docker.internal:8081
NOTIFY_GATEWAY_API_KEY=       # 게이트웨이가 발급한 schale-queue 프로젝트 전용 키
# 발송 가능 채널(게이트웨이 URL+KEY 또는 웹훅)이 하나도 없으면 워커 기동을 실패시킬지(리뷰2 M-12).
# 운영 배포에선 true 권장 — .env 오타로 알림이 '기록 없이 전량 소멸'하는 사고를 배포 시점에 차단.
NOTIFY_REQUIRED=false
#
# [폴백] 게이트웨이 미기동 시 Discord 웹훅 직접 호출(롤백 안전망, ADR-003 §4).
# Discord 채널 설정 > 연동 > 웹훅 에서 발급한 URL.
DISCORD_WEBHOOK_URL=
