# ============================================================================
#  Schale Queue - 환경변수 템플릿 (.env.example)
#  ----------------------------------------------------------------------------
#  이 파일은 '키 목록'만 공유하는 안전한 템플릿이다 (커밋 대상).
#  실제 사용 시: 복사하여 .env 를 만들고 실제 값을 채운다.  →  cp .env.example .env
#  .env 는 .gitignore 로 차단되어 절대 커밋되지 않는다. (§5.3.2)
# ============================================================================

# --- Database (MariaDB) ---
# DB_NAME / DB_USERNAME / DB_PASSWORD / DB_ROOT_PASSWORD 는 docker-compose 가 참조한다.
DB_NAME=schale_queue
DB_USERNAME=schale
DB_PASSWORD=changeme             # ← 실제 비밀번호로 교체 (절대 커밋 금지)
DB_ROOT_PASSWORD=changeme_root   # ← MariaDB root 비밀번호 (절대 커밋 금지)
# 애플리케이션(JPA) 접속 URL
DB_URL=jdbc:mariadb://localhost:3306/schale_queue

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Server ---
SERVER_PORT=8080

# --- Notifications (notify-gateway 1차 / Discord 웹훅 폴백) ---
# Claude Code 작업 알림 프로토콜(§5.3.4)은 1차로 공용 알림 게이트웨이를 호출한다.
# 🔒 모두 시크릿이다. .env 에만 채우고 절대 커밋하지 않는다.
#
# [1차] 게이트웨이 API — 채널·내용만 전달, 실제 웹훅 URL은 게이트웨이가 보유(시크릿 중앙화).
NOTIFY_GATEWAY_URL=            # 예: http://localhost:8080
NOTIFY_GATEWAY_API_KEY=       # 게이트웨이가 발급한 schale-queue 프로젝트 전용 키
#
# [폴백] 게이트웨이 미기동 시 Discord 웹훅 직접 호출(롤백 안전망, ADR-003 §4).
# Discord 채널 설정 > 연동 > 웹훅 에서 발급한 URL.
DISCORD_WEBHOOK_URL=
